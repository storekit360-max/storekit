{
  "version": 2,
  "redirects": [
    {
      "source": "/sitmap.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/site-map.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://storekit1-production.up.railway.app/api/:path*"
    },
    {
      "source": "/manifest.json",
      "destination": "https://storekit1-production.up.railway.app/api/settings/manifest.json"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "source": "/sitemap_index.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/sitemap.xml"
    },
    {
      "source": "/products-sitemap.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/products-sitemap.xml"
    },
    {
      "source": "/categories-sitemap.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/categories-sitemap.xml"
    },
    {
      "source": "/brands-sitemap.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/brands-sitemap.xml"
    },
    {
      "source": "/pages-sitemap.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/pages-sitemap.xml"
    },
    {
      "source": "/google-shopping-feed.xml",
      "destination": "https://storekit1-production.up.railway.app/api/seo/google-shopping-feed.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://storekit1-production.up.railway.app/api/seo/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(admin|superadmin|account|my-orders|wishlist|checkout|cart|login|register|forgot-password|order-success|track-order)/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/version.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
