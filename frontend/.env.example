# ─── StoreKit Frontend — Environment Variables ────────────────────────────────
# Copy to .env.local for local dev. Vercel env vars are set in the dashboard.

# Railway backend URL — only needed for local dev.
# In production on Vercel, /api/* is rewritten to Railway via vercel.json,
# so this var is not required there.
REACT_APP_API_URL=http://localhost:5001/api

# Google Sign-In does not need a frontend client-ID variable. The permanent
# bridge obtains the public client ID from the backend GOOGLE_CLIENT_ID value.

# ─── Vercel Environment Variables (set in Vercel dashboard) ──────────────────
# These are used by frontend/middleware.js (Edge Middleware):
#
#   RAILWAY_BACKEND_URL   = https://your-app.up.railway.app
#   INTERNAL_SECRET       = same value as backend INTERNAL_SECRET
#
# Set both in Vercel → Settings → Environment Variables → Production + Preview
