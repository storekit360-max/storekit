# ─── StoreKit Backend — Environment Variables ─────────────────────────────────
# Copy to .env and fill in your values. NEVER commit .env to git.

PORT=5001
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/storekit?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_random

# ─── Multi-Tenant Domain Resolution ──────────────────────────────────────────
# Shared secret between Vercel edge middleware and Railway backend.
# Used by /api/superadmin/resolve-domain. Generate with: openssl rand -hex 32
INTERNAL_SECRET=your_random_32_char_internal_secret_here

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Your Railway backend URL (no trailing slash)
BACKEND_URL=https://your-app.up.railway.app
# Your main Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
# Admin panel URL (for email links)
ADMIN_URL=https://your-app.vercel.app/admin

# ─── CORS extra origins (comma-separated) ────────────────────────────────────
# Tenant custom domains are loaded from DB automatically.
# Use EXTRA_ORIGINS for static additions (staging, etc.)
# EXTRA_ORIGINS=https://staging.yourstore.lk

# ─── Cloudinary (image CDN) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USER=resend
EMAIL_PASS=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=re_your_resend_api_key

# ─── Google Sign-In (all customer stores use one fixed OAuth bridge) ──────────
# Web application client ID used by both the bridge and backend ID-token check.
GOOGLE_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
GOOGLE_SUPERADMIN_CLIENT_ID=your_superadmin_web_client_id.apps.googleusercontent.com
# Optional defense-in-depth allowlist; accounts must also exist as active superadmins in MongoDB.
SUPERADMIN_GOOGLE_EMAILS=owner@example.com,operations@example.com
# Permanent frontend route. Register ONLY its origin (scheme + host) under
# Google Cloud → OAuth Client → Authorized JavaScript origins.
GOOGLE_AUTH_BRIDGE_URL=https://your-app.vercel.app/google-auth-bridge

# ─── Google OAuth (Drive backup) ──────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.up.railway.app/api/backup/oauth/callback

# ─── AI (OpenRouter or Gemini) ────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=meta-llama/llama-3.1-8b-instruct
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
PEXELS_API_KEY=

# ─── Social Media ─────────────────────────────────────────────────────────────
SOCIAL_MEDIA_SECRET=your_social_media_encryption_secret
# Pin to a Graph API version supported by your Meta app; update deliberately.
META_GRAPH_VERSION=v21.0
# Persistent product-post worker. Set false to pause all due-job processing.
SOCIAL_SCHEDULER_ENABLED=true
# Worker polling cadence; individual timestamps are stored in MongoDB.
SOCIAL_SCHEDULER_INTERVAL_MS=15000
# Optional cross-queue pacing per worker/platform.
SOCIAL_FACEBOOK_MIN_INTERVAL_MS=1000
SOCIAL_INSTAGRAM_MIN_INTERVAL_MS=5000
# Set false only if your image host blocks safe HEAD accessibility checks.
SOCIAL_VALIDATE_MEDIA_ACCESS=true

# ─── WhatsApp Bot (optional) ──────────────────────────────────────────────────
WHATSAPP_BOT_ENABLED=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_NUMBER=

# ─── Store ────────────────────────────────────────────────────────────────────
SHOP_NAME=StoreKit
