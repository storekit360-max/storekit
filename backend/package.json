{
  "name": "storekit-backend",
  "version": "2.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "staging": "DOTENV_CONFIG_PATH=.env.staging node -r dotenv/config server.js",
    "start:staging": "DOTENV_CONFIG_PATH=.env.staging node -r dotenv/config server.js",
    "seed:staging": "DOTENV_CONFIG_PATH=.env.staging node -r dotenv/config seed.js",
    "migrate:tenant-data": "node scripts/migrateTenantData.js",
    "migrate:social-scheduling": "node scripts/social-scheduling-migration.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.0.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^1.1.1",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "stripe": "^14.0.0",
    "unzipper": "^0.12.3",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
