APP_ENV=staging
NODE_ENV=development
PORT=5002
MONGODB_URI=mongodb://127.0.0.1:27017/shopzen_staging
JWT_SECRET=replace-with-a-long-staging-only-secret
# Versioned JWT keyring. New tokens use JWT_SIGNING_KEY_ID; keep the previous
# key in the JSON until every token it signed has expired. JWT_SECRET verifies
# legacy tokens without a kid during migration and can be removed afterwards.
# JWT_SIGNING_KEYS={"2026-07":"replace-with-at-least-32-random-characters","2026-10":"replace-with-another-32-character-random-secret"}
# JWT_SIGNING_KEY_ID=2026-10
# Versioned encryption for stored integration and MFA secrets. Keep the old key
# until the Security Center migration reports zero records using it.
# PLATFORM_SECRETS_ENCRYPTION_KEYS={"2026-07":"replace-with-at-least-32-random-characters","2026-10":"replace-with-a-new-32-character-random-secret"}
# PLATFORM_SECRETS_ENCRYPTION_KEY_ID=2026-10
CURFOX_ENCRYPTION_KEY=replace-with-a-long-staging-only-encryption-secret
PLATFORM_SECRETS_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
# Optional Anthropic integration. Prefer the encrypted Integration Center;
# environment values remain a deployment-managed fallback.
# ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# ANTHROPIC_MODEL=replace-with-approved-model-id
# Meta Ads acquisition sync. Prefer encrypted Integration Center values.
# META_AD_ACCOUNT_ID=123456789012345
# META_ADS_GRAPH_VERSION=vXX.X
# META_ADS_ACCESS_TOKEN=replace-with-system-user-token-with-ads_read
# Google Ads reporting sync. Use a dedicated OAuth grant with read-only Ads scope
# and prefer encrypted Integration Center values over environment fallbacks.
# GOOGLE_ADS_CLIENT_ID=replace-with-oauth-client-id
# GOOGLE_ADS_CLIENT_SECRET=replace-with-oauth-client-secret
# GOOGLE_ADS_REFRESH_TOKEN=replace-with-read-only-refresh-token
# GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-approved-developer-token
# GOOGLE_ADS_CUSTOMER_ID=1234567890
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=0987654321
# GOOGLE_ADS_API_VERSION=v22
# Optional dedicated/versioned backup key. Keep retired keys in BACKUP_ENCRYPTION_KEYS for restores.
BACKUP_ENCRYPTION_KEY_ID=primary
BACKUP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
# BACKUP_ENCRYPTION_KEYS={"primary":"current-key-material","2025":"retired-key-material"}
# Geo rules require a trusted edge/proxy to inject both headers. Direct Railway traffic is denied while rules are active.
# TRUSTED_GEO_HEADER=x-vercel-ip-country
# TRUSTED_EDGE_PROXY_SECRET=replace-with-at-least-32-random-characters
CURFOX_DRY_RUN=true
EMAIL_ENABLED=false
META_CAPI_ENABLED=false
WHATSAPP_ENABLED=false
SOCIAL_MEDIA_ENABLED=false
MARKETING_SENDING_ENABLED=false
PAYMENTS_ENABLED=false
ALLOW_PRODUCTION_SEED=false
EXTRA_ORIGINS=http://localhost:3001
